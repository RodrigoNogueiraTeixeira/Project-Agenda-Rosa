# BANCO DE DADOS (PostgreSQL - Neon.tech)
# Copie a connection string fornecida pelo Neon.
DATABASE_URL=postgresql://usuario:senha@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# SERVIDOR
PORT=3001

# ACESSO ADMINISTRATIVO
# Gere o hash dentro da pasta backend:
# node -e "console.log(require('./src/utils/password').hashPassword('sua-senha'))"
ADMIN_EMAIL=admin@agendarosa.com
ADMIN_PASSWORD_HASH=

# ENDERECO PUBLICO OU LOCAL DA APLICACAO
# Local: http://localhost:3001
# Render: https://seu-backend.onrender.com
APP_BASE_URL=http://localhost:3001

# MERCADO PAGO (opcional)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_URL=http://localhost:3001/api/pagamentos/mercadopago/webhook

# OPEN ROUTE SERVICE (opcional)
ORS_API_KEY=

# RECUPERACAO DE SENHA PELO BREVO (opcional)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# SEGURANCA JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui
