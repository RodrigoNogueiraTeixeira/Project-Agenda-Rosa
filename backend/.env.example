# Variáveis de Ambiente - Agenda Rosa Backend

# ============================================================
# BANCO DE DADOS (PostgreSQL - Neon.tech)
# ============================================================
# Cole aqui a connection string fornecida pelo Neon.tech.
# Acesse: https://neon.tech → Seu Projeto → Connection Details
# Formato: postgresql://usuario:senha@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=postgresql://usuario:senha@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ============================================================
# SERVIDOR
# ============================================================
PORT=3001

# ============================================================
# URL BASE DA APLICAÇÃO (necessário para webhooks do Mercado Pago)
# ============================================================
# Em desenvolvimento local com ngrok:
# APP_BASE_URL=https://seu-subdominio.ngrok-free.app
# Em produção no Render:
# APP_BASE_URL=https://seu-backend.onrender.com

APP_BASE_URL=https://seu-backend.onrender.com

# ============================================================
# MERCADO PAGO (opcional - necessário para pagamentos)
# ============================================================
# Acesse: https://www.mercadopago.com.br/developers/pt/docs

MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_URL=${APP_BASE_URL}/api/pagamentos/mercadopago/webhook

# ============================================================
# OPEN ROUTE SERVICE (opcional - necessário para distância por GPS)
# ============================================================
# Acesse: https://openrouteservice.org/

ORS_API_KEY=
