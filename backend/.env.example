# -----------------------------------------------------------------------------
# AGENDA ROSA - ARQUIVO DE CONFIGURAÇÃO DE EXEMPLO (.env.example)
#
# Para usar localmente:
# 1. Duplique este arquivo e mude o nome para '.env'
# 2. Preencha as chaves com os valores correspondentes de desenvolvimento.
# -----------------------------------------------------------------------------

# Porta onde o servidor Express irá rodar localmente
PORT=3001

# URL base da API (usada no redirecionamento do front-end)
APP_BASE_URL=http://localhost:3001

# =============================================================================
# BANCO DE DADOS (SQLITE HÍBRIDO / TURSO CLOUD)
# =============================================================================
# Deixe as variáveis abaixo em BRANCO localmente para que o sistema use 
# automaticamente o SQLite em arquivo físico local (data/agendarosa.db).
# No Render (Produção), preencha com as credenciais do seu banco Turso na Nuvem.
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu_auth_token_secreto_aqui

# =============================================================================
# INTEGRAÇÃO MERCADO PAGO (PAGAMENTOS E WEBHOOKS)
# =============================================================================
# Credenciais do Mercado Pago para validação de pagamentos e webhooks do Pix.
MP_ACCESS_TOKEN=seu_access_token_do_mercado_pago
MP_PUBLIC_KEY=seu_public_key_do_mercado_pago

# URL do Webhook do Mercado Pago (onde ele envia atualizações de Pix)
# Em ambiente local, use uma URL do ngrok (ex: https://XXXX.ngrok-free.app/api/webhook)
# Em produção, use a URL oficial do Render (ex: https://agenda-rosa.onrender.com/api/webhook)
MP_WEBHOOK_URL=http://localhost:3001/api/webhook
